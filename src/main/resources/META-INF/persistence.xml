<?xml version="1.0" encoding="UTF-8" ?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="Oblig3" transaction-type="RESOURCE_LOCAL">
        <class>org.example.Entity.Prosjekt</class>
        <class>org.example.Entity.Avdeling</class>
        <class>org.example.Entity.ProsjektDeltagelse</class>

        <class>org.example.Entity.Ansatt</class>
        <properties>
            <!-- Generelle JPA properties -->
            <property name="jakarta.persistence.jdbc.driver"
                      value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url"
                          value="jdbc:postgresql://ider-database.westeurope.cloudapp.azure.com:5433/keaus8981"/>
<!--                      value="jdbc:postgresql://ider-database.westeurope.cloudapp.azure.com:5433/postgres"/>-->
            <property name="jakarta.persistence.jdbc.user" value="keaus8981"/>
            <property name="jakarta.persistence.jdbc.password" value="pass"/>
            <!-- EclipseLink properties -->
            <!-- Se https://wiki.eclipse.org/EclipseLink/Examples/JPA/Logging -->
            <property name="eclipselink.logging.level" value="WARNING"/>
        </properties>
    </persistence-unit>
</persistence>